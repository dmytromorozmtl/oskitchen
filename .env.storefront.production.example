# =============================================================================
# Storefront production — copy values into Vercel → Project → Settings → Environment Variables
# NEVER commit this file with real secrets. Use 1Password / Vercel encrypted storage.
# Validate:  cp .env.storefront.production.example .env.production.local  # fill values
#            npm run check-env:storefront
# =============================================================================

# --- P0 critical (all storefront releases) ---
DATABASE_URL=
DIRECT_URL=
NEXT_PUBLIC_APP_URL=https://app.yourdomain.com
STOREFRONT_MIDDLEWARE_SECRET=
CRON_SECRET=
AUTH_SECRET=

# Supabase (dashboard + storage) — usually same as main KitchenOS project
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Email (if order/contact notifications enabled) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# --- Preview (draft iframe + signed preview) ---
# STOREFRONT_PREVIEW_SECRET=   # optional; falls back to AUTH_SECRET if ≥32 chars

# --- Custom domains ---
# NEXT_PUBLIC_STOREFRONT_ROOT_DOMAIN=orders.yourdomain.com

# --- A3 Option B only: Stripe online checkout ---
# STRIPE_SECRET_KEY=sk_live_
# STRIPE_WEBHOOK_SECRET=whsec_
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_
# STOREFRONT_STRIPE_CURRENCY=usd

# --- Week 1: bot protection (recommended) ---
# See docs/artifacts/STOREFRONT_TURNSTILE_VERCEL_SETUP.md
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=
# STOREFRONT_REDIRECTS_ENABLED=true
# Week 1 local template: .env.storefront.week1.example

# --- Phase C / Week 2 media (Supabase Storage) ---
# npm run storefront:setup-media-bucket
# STOREFRONT_SUPABASE_STORAGE_BUCKET=storefront-media
# (requires NEXT_PUBLIC_SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY from main .env)

# --- Week 2–4: media upload (S3-compatible) ---
# STOREFRONT_S3_BUCKET=
# STOREFRONT_S3_REGION=
# STOREFRONT_S3_ACCESS_KEY_ID=
# STOREFRONT_S3_SECRET_ACCESS_KEY=
# STOREFRONT_S3_PUBLIC_BASE_URL=

# --- CI / staging smoke (GitHub secrets, not Vercel prod) ---
# PLAYWRIGHT_BASE_URL=https://staging.yourdomain.com
# E2E_STOREFRONT_SLUG=your-published-slug

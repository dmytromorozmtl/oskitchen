# =============================================================================
# KitchenOS — STAGING / PAID PILOT (template for Ops)
# =============================================================================
# 1. Copy:  cp .env.staging.template .env.staging
# 2. Fill every REQUIRED value (no placeholders left)
# 3. Validate:  npm run verify:staging-env
# 4. Optional local mirror:  cp .env.staging .env.staging.local
# 5. Push to Vercel:  npm run vercel:staging-push -- --apply
#    OR:  bash scripts/ops/setup-vercel-env.sh
#
# NEVER commit .env.staging or .env.staging.local with real secrets.
# =============================================================================

NODE_ENV=production
NEXT_PUBLIC_APP_ENV=staging

# REQUIRED — canonical staging URL (update after each Vercel redeploy)
NEXT_PUBLIC_APP_URL=https://YOUR-PREVIEW.vercel.app

# REQUIRED — Supabase poolers (Transaction :6543 + Session :5432)
DATABASE_URL=postgresql://postgres.PROJECT:PASSWORD@aws-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=10
DIRECT_URL=postgresql://postgres.PROJECT:PASSWORD@aws-REGION.pooler.supabase.com:5432/postgres

# REQUIRED — Supabase Auth
NEXT_PUBLIC_SUPABASE_URL=https://PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# REQUIRED — encrypts integration tokens (openssl rand -base64 64)
ENCRYPTION_KEY=

# REQUIRED — Vercel Cron Bearer secret (openssl rand -base64 48)
CRON_SECRET=

# REQUIRED for paid pilot — distributed rate limits
RATE_LIMIT_ADAPTER=upstash
UPSTASH_REDIS_REST_URL=https://YOUR-ENDPOINT.upstash.io
UPSTASH_REDIS_REST_TOKEN=

# REQUIRED for pilot UX — hides non-pilot sidebar modules
NEXT_PUBLIC_NAV_RELEASE_PROFILE=pilot

# REQUIRED for platform support impersonation (npm run setup:impersonation-totp)
PLATFORM_IMPERSONATION_TOTP_SECRET=

# RECOMMENDED — error tracking
SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=

# REQUIRED if storefront checkout enabled (Stripe test mode on staging)
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_

# RECOMMENDED — transactional email
RESEND_API_KEY=
RESEND_FROM_EMAIL="KitchenOS <notifications@yourdomain.com>"

# OPTIONAL — async webhook processing (requires /api/cron/webhook-jobs scheduled)
# WEBHOOK_ASYNC_QUEUE=true

# DANGER — leave UNSET on staging pilot (experimental crons return 404 in production)
# ENABLE_EXPERIMENTAL_CRONS=

# -----------------------------------------------------------------------------
# E2E / QA (shell only — do NOT add to Vercel unless required)
# -----------------------------------------------------------------------------
# PLAYWRIGHT_BASE_URL=https://YOUR-PREVIEW.vercel.app
# E2E_PILOT_EMAIL=pilot-owner@yourdomain.com
# E2E_PILOT_PASSWORD=
# E2E_PILOT_STAFF_EMAIL=
# E2E_PILOT_STAFF_PASSWORD=
# E2E_TEST_STORE_SLUG=your-store-slug

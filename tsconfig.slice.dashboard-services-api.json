{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "plugins": [],
    "tsBuildInfoFile": "./.tsbuildinfo.slice.dashboard-services-api"
  },
  "include": [
    "next-env.d.ts",
    "middleware.ts",
    "instrumentation.ts",
    "app/layout.tsx",
    "app/global-error.tsx",
    "app/not-found.tsx",
    "app/opengraph-image.tsx",
    "app/api/**/*.ts",
    "app/api/**/*.tsx",
    "app/dashboard/**/*.ts",
    "app/dashboard/**/*.tsx",
    "components/**/*.ts",
    "components/**/*.tsx",
    "lib/**/*.ts",
    "lib/**/*.tsx",
    "hooks/**/*.ts",
    "hooks/**/*.tsx",
    "actions/**/*.ts",
    "actions/**/*.tsx",
    "services/**/*.ts",
    "services/**/*.tsx",
    "stores/**/*.ts",
    "stores/**/*.tsx",
    "types/**/*.ts",
    "prisma/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "playwright.config.ts",
    "e2e",
    "tests",
    "scripts",
    "archive",
    "**/.next.trash.*/**",
    "**/.next.deploy-trash.*/**",
    "**/.next-stale-*/**",
    ".vercel/**",
    ".next/cache/**",
    ".next/static/**",
    ".next/server/**"
  ]
}

# E2E — auto-generated by: npm run e2e:bootstrap  →  .env.e2e.local (gitignored)
# Or copy manually:

# E2E_LOGIN_EMAIL=owner@kitchen.com
# E2E_LOGIN_PASSWORD=
# PLAYWRIGHT_BASE_URL=https://os-kitchen.com
# E2E_SEED_USER_ID=

# E2E pilot — copy to .env.e2e or export before npm run test:e2e:pilot
# Requires live staging deploy (PLAYWRIGHT_BASE_URL returns 200 on /api/health)

PLAYWRIGHT_BASE_URL=https://YOUR-PREVIEW.vercel.app
E2E_PILOT_EMAIL=pilot-owner@yourdomain.com
E2E_PILOT_PASSWORD=

# Optional staff tenancy spec
# E2E_PILOT_STAFF_EMAIL=
# E2E_PILOT_STAFF_PASSWORD=

# Storefront HTTP specs
# E2E_TEST_STORE_SLUG=your-store-slug
# E2E_STOREFRONT_SLUG=your-store-slug

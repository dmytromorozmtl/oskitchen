# =============================================================================
# KitchenOS — copy to `.env.local` (never commit real secrets).
# See docs/ENVIRONMENT_VARIABLES.md for required vs optional and Vercel setup.
# =============================================================================

# -----------------------------------------------------------------------------
# APP  (public where marked)
# -----------------------------------------------------------------------------
# Canonical URL for redirects, Stripe return URLs, metadata — REQUIRED in prod
# PUBLIC
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google Search Console — HTML tag verification (see docs/GSC_SETUP.md)
# PUBLIC
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your-verification-token

# PostHog product analytics (optional — npm package posthog-js)
# PUBLIC
# NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxx
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# NPS survey — full Typeform URL (optional; in-app 0–10 works without)
# PUBLIC
# NEXT_PUBLIC_NPS_SURVEY_URL=https://form.typeform.com/to/xxxxx

# Google Analytics (marketing site — GA4 measurement ID)
# PUBLIC
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Ads conversion tag (optional — AW-XXXXXXXXX)
# PUBLIC
# NEXT_PUBLIC_GOOGLE_ADS_ID=AW-XXXXXXXXX

# Meta (Facebook) Pixel — numeric ID only (optional)
# PUBLIC
# NEXT_PUBLIC_META_PIXEL_ID=000000000000000

# LinkedIn Insight Tag partner ID (optional)
# PUBLIC
# NEXT_PUBLIC_LINKEDIN_PARTNER_ID=0000000

# HubSpot embedded forms (optional — native forms used when unset)
# PUBLIC
# NEXT_PUBLIC_HUBSPOT_PORTAL_ID=0000000
# NEXT_PUBLIC_HUBSPOT_REGION=na1
# NEXT_PUBLIC_HUBSPOT_SALES_FORM_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# NEXT_PUBLIC_HUBSPOT_DEMO_FORM_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Hero product tour embed (YouTube, Loom, or Vimeo URL — optional)
# PUBLIC
# NEXT_PUBLIC_DEMO_VIDEO_URL=https://www.youtube.com/watch?v=YOUR_VIDEO_ID

# Optional UI label: development | staging | production
# PUBLIC
# NEXT_PUBLIC_APP_ENV=development

# Optional — enables dashboard mailto feedback / bug links
# PUBLIC (email address only)
# NEXT_PUBLIC_SUPPORT_EMAIL=team@yourdomain.com

NODE_ENV=development

# -----------------------------------------------------------------------------
# LEGAL (SECRET — server only)
# -----------------------------------------------------------------------------
# When unset or not "true": /legal/privacy and /legal/terms use noindex and show draft UI.
# Set to true only after counsel-approved policies are deployed.
# LEGAL_POLICIES_PUBLISHED=

# -----------------------------------------------------------------------------
# E2E (local / CI — never commit real passwords)
# -----------------------------------------------------------------------------
# Optional — enables Playwright dashboard + POS flows (requires running Next + DB + valid user).
# E2E_LOGIN_EMAIL=
# E2E_LOGIN_PASSWORD=
# E2E_STAFF_EMAIL=              # closed-beta staff visibility (step 5)
# E2E_STAFF_PASSWORD=
# BETA_COHORT_EMAILS=           # comma-separated owner emails for step 6
# Same Supabase user UUID — run `npm run db:seed:e2e-pos` once so POS checkout E2E has register, staff, PRO plan, catalog.
# E2E_SEED_USER_ID=
# Optional — published storefront slug for `npm run test:e2e:storefront` / remote workflow
# E2E_STOREFRONT_SLUG=

# -----------------------------------------------------------------------------
# STOREFRONT  (see .env.storefront.production.example for prod checklist)
# -----------------------------------------------------------------------------
# SECRET — custom host + redirect resolution (≥32 chars)
# STOREFRONT_MIDDLEWARE_SECRET=
# SECRET — signed draft preview (optional; AUTH_SECRET fallback)
# STOREFRONT_PREVIEW_SECRET=
# PUBLIC — subdomain root for vanity hosts
# NEXT_PUBLIC_STOREFRONT_ROOT_DOMAIN=orders.yourdomain.com
# Enable middleware redirect table lookup
# STOREFRONT_REDIRECTS_ENABLED=true
# Turnstile (checkout + contact when both set)
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=
# Media bucket — Supabase or S3 (see docs/STOREFRONT_MEDIA_LIBRARY.md)
# STOREFRONT_SUPABASE_STORAGE_BUCKET=storefront-media
# STOREFRONT_S3_BUCKET=
# STOREFRONT_S3_REGION=
# STOREFRONT_S3_ACCESS_KEY_ID=
# STOREFRONT_S3_SECRET_ACCESS_KEY=
# STOREFRONT_S3_PUBLIC_BASE_URL=

# When true + NODE_ENV=development: skip subscription/trial enforcement locally
DEV_BYPASS_BILLING=

# -----------------------------------------------------------------------------
# SUPABASE  (mixed)
# -----------------------------------------------------------------------------
# PUBLIC — Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# PUBLIC — anon key (browser-safe)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# SECRET — server only; never expose to client bundles
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# -----------------------------------------------------------------------------
# ENTERPRISE SSO (Auth0 / Okta / Entra — staging smoke; see docs)
# KitchenOS uses Supabase Auth sessions, NOT @auth0/nextjs-auth0 SDK routes.
# Auth0 setup: docs/auth0-supabase-saml-setup.md
# Smoke plan: docs/enterprise-sso-idp-staging-smoke-plan.md
# -----------------------------------------------------------------------------
# E2E_STAGING_BASE_URL=https://staging.yourdomain.com
# SSO_STAGING_WORKSPACE_ID=
# SSO_STAGING_IDP_VENDOR=AUTH0
# SSO_STAGING_ALLOWED_DOMAIN=pilot.example.com
# SSO_STAGING_TEST_EMAIL=staff@pilot.example.com
# SSO_STAGING_SUPABASE_PROVIDER_REF=
# Auth0 tenant reference (ops vault only — for SAML IdP app, not Next.js SDK):
# AUTH0_DOMAIN=dev-xxxxx.us.auth0.com
# AUTH0_CLIENT_ID=
# AUTH0_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# PRISMA / DATABASE  (SECRET — server only)
# -----------------------------------------------------------------------------
# DATABASE_URL = Supabase **Transaction Pooler** on :6543 — used by the Next.js
# runtime / serverless. Requires `pgbouncer=true` so Prisma skips prepared
# statements (transaction-mode pgbouncer doesn't keep session state).
# Copy from Supabase → Settings → Database → "Transaction Pooler".
DATABASE_URL="postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=10&pool_timeout=30"

# DIRECT_URL = Supabase **Session Pooler** on :5432 — used by Prisma CLI
# (`prisma migrate deploy`, `prisma migrate status`, introspection). Same host
# as the transaction pooler, just port 5432 and **no** `pgbouncer=true`.
# Copy from Supabase → Settings → Database → "Session Pooler".
#
# Do NOT use the legacy direct host `db.<ref>.supabase.co:5432` — that endpoint
# is IPv6-only on current Supabase plans and is unreachable from most networks.
# See docs/SUPABASE_POOLER_SETUP.md for migration steps.
DIRECT_URL="postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-REGION.pooler.supabase.com:5432/postgres"

# -----------------------------------------------------------------------------
# SECURITY  (SECRET — server only)
# -----------------------------------------------------------------------------
# REQUIRED prod — encrypts stored integration tokens (openssl rand -base64 32)
ENCRYPTION_KEY=

# RECOMMENDED — Vercel Cron sends Authorization: Bearer CRON_SECRET when set
CRON_SECRET=

# DANGER — pilot/production: leave UNSET. When true, non-allowlisted /api/cron/* routes may run (see production-manifest.ts).
# ENABLE_EXPERIMENTAL_CRONS=

# Optional — when true, WooCommerce + Shopify webhooks enqueue DB jobs and return fast (requires cron /api/cron/webhook-jobs)
WEBHOOK_ASYNC_QUEUE=

# Optional — webhook worker batch size for /api/cron/webhook-jobs (default 40)
WEBHOOK_JOB_BATCH_SIZE=

# Optional — max attempts per webhook job before FAILED (default 5)
WEBHOOK_JOB_MAX_ATTEMPTS=

# Optional — pilot navigation hides deep sidebar modules (forecast, purchasing, copilot, …). Values: pilot | full
NEXT_PUBLIC_NAV_RELEASE_PROFILE=

# Optional observability (safe no-ops when unset)
SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.05
# NEXT_PUBLIC_SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0

# Optional — distributed rate limits (server only). Pilot production: use upstash when Upstash credentials are set.
# RATE_LIMIT_ADAPTER=memory
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# REDIS_URL=

# Platform impersonation MFA (staging/prod — see .env.staging.example)
# PLATFORM_IMPERSONATION_TOTP_SECRET=
# PLATFORM_IMPERSONATION_STEP_UP_TOKEN=

# Optional — audit metadata for replay / destructive reasons (see docs/REPLAY_REASON_PII_POLICY.md)
# AUDIT_REASON_RETENTION_MODE=PREVIEW_ONLY

OTEL_EXPORTER_OTLP_ENDPOINT=

# Optional large-file pipeline (roadmap — presence reserved for future workers)
OBJECT_STORAGE_BUCKET=

# Optional shared secret for custom webhook signing
WEBHOOK_SIGNING_SECRET=

# -----------------------------------------------------------------------------
# STRIPE  (mixed)
# -----------------------------------------------------------------------------
# SECRET
STRIPE_SECRET_KEY=sk_test_

# SECRET — from Stripe webhook endpoint
STRIPE_WEBHOOK_SECRET=whsec_

# PUBLIC — Checkout Elements if used
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_

# PUBLIC — recurring price IDs
NEXT_PUBLIC_STRIPE_STARTER_PRICE_ID=price_
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_
NEXT_PUBLIC_STRIPE_TEAM_PRICE_ID=price_
NEXT_PUBLIC_STRIPE_ENTERPRISE_PRICE_ID=price_

# -----------------------------------------------------------------------------
# EMAIL / RESEND  (SECRET)
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_
RESEND_FROM_EMAIL="KitchenOS <notifications@yourdomain.com>"

# -----------------------------------------------------------------------------
# SHOPIFY  (SECRET)
# -----------------------------------------------------------------------------
SHOPIFY_APP_SECRET=
SHOPIFY_API_VERSION=2024-10

# -----------------------------------------------------------------------------
# WOOCOMMERCE  (SECRET)
# -----------------------------------------------------------------------------
WOOCOMMERCE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# UBER  (SECRET)
# -----------------------------------------------------------------------------
UBER_EATS_CLIENT_ID=
UBER_EATS_CLIENT_SECRET=
# HMAC secret for Uber Eats order webhooks (or set per-connection webhook secret in Integrations)
UBER_EATS_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# SMS (Twilio) — optional customer notifications
# -----------------------------------------------------------------------------
SMS_NOTIFICATIONS_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
UBER_DIRECT_CLIENT_ID=
UBER_DIRECT_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# DEMO / AUTOMATION
# -----------------------------------------------------------------------------
# When true/1: allows demo import/reset on production hosts (supervised beta)
DEMO_MODE_ENABLED=
# Protects automated demo seed HTTP if implemented
DEMO_SEED_SECRET=

# -----------------------------------------------------------------------------
# OPTIONAL — AI & maps (server only; never expose to the browser)
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=
# GOOGLE_MAPS_API_KEY=

# -----------------------------------------------------------------------------
# SEED CLI (prisma/seed.ts) — optional
# -----------------------------------------------------------------------------
# SEED_USER_ID=
# SEED_USER_EMAIL=demo@kitchenos.app
# SEED_RESET=

{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "true",
  "buildCommand": "npx prisma generate && NODE_OPTIONS=--max-old-space-size=8192 npm run build",
  "regions": [
    "iad1"
  ],
  "crons": [
    {
      "path": "/api/cron/webhook-jobs",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/reminders",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron/storefront-domain-recheck",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/storefront-cart-recovery",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/storefront-theme-publish",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/storefront-team-invite-reminders",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/storefront-webhook-retention",
      "schedule": "15 4 * * *"
    },
    {
      "path": "/api/cron/storefront-invite-audit-retention",
      "schedule": "0 3 * * 0"
    },
    {
      "path": "/api/cron/storefront-ga4-parity",
      "schedule": "30 */6 * * *"
    },
    {
      "path": "/api/cron/storefront-edge-sync",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/cron/pilot-daily-health",
      "schedule": "0 8 * * *"
    }
  ]
}

# Local pilot storefront — copy to .env.storefront.local (gitignored)
# Your test store: http://localhost:3000/s/hello

STOREFRONT_SMOKE_BASE_URL=http://localhost:3000
STOREFRONT_SMOKE_SLUG=hello
STOREFRONT_STRIPE_OPTION=A
PLAYWRIGHT_BASE_URL=http://localhost:3000
LHCI_BASE_URL=http://localhost:3000
E2E_STORE_SLUG=hello

# Phase 0 pilot defaults (leave experiments off in prod)
# STOREFRONT_EXPERIMENTS_ENABLED=1
# STOREFRONT_SERVER_CART=0
#
# Server cart in dev: npm run dev:safe injects AUTH_SECRET from .env.production.local
# (never `source .env.production.local` — breaks DATABASE_URL)

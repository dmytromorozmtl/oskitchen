# Week 1 hardening — copy to .env.production.local (merge) or export before week1-complete
# Never commit real secrets.

# ── Turnstile (Cloudflare) ──
# Production: real keys from dashboard
# Staging test (always pass): site 1x00000000000000000000AA / secret 1x0000000000000000000000000000000AA
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── Redirects (after DB seed) ──
STOREFRONT_REDIRECTS_ENABLED=true
STOREFRONT_MIDDLEWARE_SECRET=

# ── Smoke targets ──
STOREFRONT_SMOKE_BASE_URL=https://xn---production-xijza32a.vercel.app
STOREFRONT_SMOKE_SLUG=hello
PLAYWRIGHT_BASE_URL=https://xn---preview--staging-r4nxb5ja9d6q.vercel.app
LHCI_BASE_URL=https://xn---preview--staging-r4nxb5ja9d6q.vercel.app
E2E_STORE_SLUG=hello

# ── Week 2 media (optional with week1-complete) ──

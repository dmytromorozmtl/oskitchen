# Copy to .env.smoke.local or .env.integration-sandbox.local (gitignored) and fill for live channel smokes.
# Full 18 LIVE template: .env.integration-sandbox.example
# See docs/live-integrations-staging-smoke-setup.md and docs/woocommerce-credentials-guide.md

# --- Shared (staging) ---
E2E_STAGING_BASE_URL=https://staging.example.com
DATABASE_URL=postgresql://user:pass@host:5432/kitchenos
ENCRYPTION_KEY=
CHANNEL_SMOKE_CONNECTION_ID=
CHANNEL_SMOKE_OWNER_EMAIL=owner@example.com

# --- WooCommerce (Path A: direct store) ---
WOOCOMMERCE_BASE_URL=https://your-store.example
WOOCOMMERCE_CONSUMER_KEY=ck_...
WOOCOMMERCE_CONSUMER_SECRET=cs_...
WOOCOMMERCE_WEBHOOK_SECRET=

# --- Shopify (Path A: direct store) ---
SHOPIFY_SHOP_DOMAIN=your-store.myshopify.com
SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_...
SHOPIFY_APP_SECRET=
# SHOPIFY_API_VERSION=2024-10

# Run (scripts auto-load this file when named .env.smoke.local):
#   npm run smoke:woo-live
#   npm run smoke:shopify-live
#   npm run smoke:live-integrations-staging   # fleet — all 18 LIVE surfaces

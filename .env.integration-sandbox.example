# Integration sandbox — test credentials for 18 LIVE integrations (P1-33)
# Copy to .env.integration-sandbox.local (gitignored) or merge into .env.smoke.local
# See docs/live-integrations-staging-smoke-setup.md

# --- Shared staging sandbox ---
E2E_STAGING_BASE_URL=https://staging.example.com
DATABASE_URL=postgresql://user:pass@host:5432/kitchenos
ENCRYPTION_KEY=
CHANNEL_SMOKE_CONNECTION_ID=
CHANNEL_SMOKE_OWNER_EMAIL=owner@example.com

# --- WooCommerce ---
WOOCOMMERCE_BASE_URL=https://your-store.example
WOOCOMMERCE_CONSUMER_KEY=ck_sandbox_...
WOOCOMMERCE_CONSUMER_SECRET=cs_sandbox_...
WOOCOMMERCE_WEBHOOK_SECRET=whsec_sandbox_...

# --- Shopify ---
SHOPIFY_SHOP_DOMAIN=your-store.myshopify.com
SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_sandbox_...
SHOPIFY_APP_SECRET=shpss_sandbox_...

# --- Uber Eats ---
UBER_EATS_CLIENT_ID=sandbox_client_id
UBER_EATS_CLIENT_SECRET=sandbox_client_secret
UBER_EATS_STORE_ID=store_sandbox_...
UBER_EATS_WEBHOOK_SECRET=ue_webhook_sandbox_...

# --- DoorDash ---
DOORDASH_API_KEY=dd_sandbox_...
DOORDASH_MERCHANT_ID=merchant_sandbox_...
DOORDASH_WEBHOOK_SECRET=dd_webhook_sandbox_...

# --- Grubhub ---
GRUBHUB_CLIENT_ID=gh_sandbox_client_id
GRUBHUB_CLIENT_SECRET=gh_sandbox_client_secret
GRUBHUB_MERCHANT_ID=gh_merchant_sandbox_...
GRUBHUB_WEBHOOK_SECRET=gh_webhook_sandbox_...

# --- Skip / Just Eat ---
SKIP_API_KEY=skip_sandbox_...
SKIP_RESTAURANT_ID=restaurant_sandbox_...
SKIP_WEBHOOK_SECRET=skip_webhook_sandbox_...

# --- QuickBooks ---
QUICKBOOKS_CLIENT_ID=qb_sandbox_client_id
QUICKBOOKS_CLIENT_SECRET=qb_sandbox_client_secret
QUICKBOOKS_REALM_ID=qb_realm_sandbox_...

# --- Xero ---
XERO_CLIENT_ID=xero_sandbox_client_id
XERO_CLIENT_SECRET=xero_sandbox_client_secret
XERO_TENANT_ID=xero_tenant_sandbox_...

# --- 7shifts ---
SEVEN_SHIFTS_API_KEY=7shifts_sandbox_...
SEVEN_SHIFTS_COMPANY_ID=company_sandbox_...

# --- Homebase ---
HOMEBASE_API_KEY=homebase_sandbox_...
HOMEBASE_LOCATION_ID=location_sandbox_...

# --- Klaviyo ---
KLAVIYO_PRIVATE_API_KEY=pk_sandbox_...
KLAVIYO_LIST_ID=list_sandbox_...

# --- Mailchimp ---
MAILCHIMP_API_KEY=mc_sandbox_...
MAILCHIMP_SERVER_PREFIX=us21
MAILCHIMP_LIST_ID=list_sandbox_...

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_sandbox_...
STRIPE_WEBHOOK_SECRET=whsec_stripe_sandbox_...

# --- Square Payments ---
SQUARE_ACCESS_TOKEN=sq0atp_sandbox_...
SQUARE_LOCATION_ID=location_sandbox_...
SQUARE_WEBHOOK_SIGNATURE_KEY=sq_webhook_sandbox_...

# --- Moneris ---
MONERIS_STORE_ID=store_sandbox_...
MONERIS_API_TOKEN=moneris_sandbox_...

# --- OpenTable ---
OPENTABLE_CLIENT_ID=ot_sandbox_client_id
OPENTABLE_CLIENT_SECRET=ot_sandbox_client_secret
OPENTABLE_RID=rid_sandbox_...

# --- Resy ---
RESY_API_KEY=resy_sandbox_...

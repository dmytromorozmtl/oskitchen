{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "plugins": [],
    "tsBuildInfoFile": "./.tsbuildinfo.slice.services-core"
  },
  "include": [
    "next-env.d.ts",
    "lib/**/*.ts",
    "lib/**/*.tsx",
    "hooks/**/*.ts",
    "hooks/**/*.tsx",
    "actions/**/*.ts",
    "actions/**/*.tsx",
    "services/**/*.ts",
    "services/**/*.tsx",
    "stores/**/*.ts",
    "stores/**/*.tsx",
    "types/**/*.ts",
    "prisma/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "playwright.config.ts",
    "e2e",
    "tests",
    "scripts",
    "archive",
    "**/.next.trash.*/**",
    "**/.next.deploy-trash.*/**",
    "**/.next-stale-*/**",
    ".vercel/**"
  ]
}

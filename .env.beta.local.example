# KitchenOS closed-beta local env
# Copy: cp .env.beta.local.example .env.beta.local  (NEVER commit .env.beta.local)
# Load order: .env → .env.local → .env.beta.local → .env.staging.local
# Validate: npm run beta:env-check -- --all

# ═══════════════════════════════════════════════════════════════
# STEP 0 — Day 1 smoke + Playwright (required for beta:day1-complete)
# ═══════════════════════════════════════════════════════════════
SMOKE_BASE_URL=https://staging.yourdomain.com
SMOKE_PUBLIC_API_KEY=kos_your_staging_key
# Auto-filled by beta:day1-complete if empty:
SMOKE_SESSION_COOKIE=
SMOKE_DELIVERY_CONNECTION_ID=
# Tenant B UUID — required for IDOR cross-tenant test:
SMOKE_DELIVERY_CONNECTION_ID_OTHER=00000000-0000-0000-0000-000000000002

E2E_LOGIN_EMAIL=owner@pilot.com
E2E_LOGIN_PASSWORD=
E2E_STAFF_EMAIL=staff@pilot.com
E2E_STAFF_PASSWORD=

# Staging DB (required on host running beta:staging-prep / check:backfill)
DATABASE_URL=postgresql://...
DIRECT_URL=postgresql://...

# ═══════════════════════════════════════════════════════════════
# STEP 1–2 — Cohort + support
# ═══════════════════════════════════════════════════════════════
BETA_COHORT_EMAILS=chef1@,chef2@,chef3@
BETA_OWNER_EMAIL=chef1@

NEXT_PUBLIC_SUPPORT_EMAIL=team@yourdomain.com
NEXT_PUBLIC_APP_URL=https://staging.yourdomain.com
BETA_SLACK_WEBHOOK_URL=

# ═══════════════════════════════════════════════════════════════
# Staging infra (verify:staging-env --strict)
# ═══════════════════════════════════════════════════════════════
NEXT_PUBLIC_APP_ENV=staging
RATE_LIMIT_ADAPTER=upstash
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
CRON_SECRET=
PLATFORM_IMPERSONATION_TOTP_SECRET=
RESEND_API_KEY=

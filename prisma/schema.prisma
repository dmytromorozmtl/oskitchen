model MealPlanEvent {
  id           String            @id @default(uuid()) @db.Uuid
  mealPlanId   String            @map("meal_plan_id") @db.Uuid
  cycleId      String?           @map("cycle_id") @db.Uuid
  eventType    MealPlanEventType

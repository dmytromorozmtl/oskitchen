enum MealPlanType {
  INDIVIDUAL
  FAMILY
  CORPORATE_LUNCH
  OFFICE_ROTATION
  FITNESS_PLAN
  SENIOR_MEALS
  CUSTOM
  TRIAL_PLAN
}

enum MealPlanStatus {
  DRAFT
  ACTIVE
  PAUSED
  CANCELLED
  EXPIRED
  NEEDS_REVIEW
  COMPLETED
}

enum MealPlanFrequency {
  WEEKLY
  BIWEEKLY
  MONTHLY
  CUSTOM_RRULE
}

enum MealPlanFulfillmentMode {
  PICKUP
  DELIVERY
  MIXED
}

enum MealPlanBillingMode {
  PAY_LATER
  MANUAL_INVOICE

// =============================================================================
// B2B HoReCa Marketplace
// Prefixed names avoid clashes with supplier PurchaseOrder and ProductCategory enum.
// =============================================================================

enum VendorType {
  MANUFACTURER
  DISTRIBUTOR
  SERVICE_COMPANY
  COMBO
}

enum VendorStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
  SUSPENDED
  DEACTIVATED
}

enum VendorPlanTier {
  FREE
  GROWTH
  ENTERPRISE
}

enum MarketplaceProductStatus {
  DRAFT
  PENDING_REVIEW
  ACTIVE
  OUT_OF_STOCK
  ARCHIVED
}

enum MarketplacePriceUnit {
  PER_UNIT
  PER_CASE
  PER_KG
  PER_LITRE
  PER_PALLET
}

enum MarketplaceCurrency {
  USD
  EUR
  GBP
  CAD
}

enum MarketplaceStorageRequirement {
  AMBIENT
  REFRIGERATED
  FROZEN
  HAZMAT
}

enum MarketplaceWeightUnit {
  G
  KG
  OZ
  LB
}

enum MarketplacePOStatus {
  DRAFT
  PENDING_APPROVAL
  SUBMITTED
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  COMPLETED
  DISPUTED
  CANCELLED
}

enum MarketplacePaymentMethod {
  CARD
  ACH
  NET_TERMS
  WALLET
}

enum MarketplaceRecurringFrequency {
  WEEKLY
  BIWEEKLY
  MONTHLY
}

enum MarketplaceDisputeReason {
  DAMAGED
  NOT_AS_DESCRIBED
  WRONG_ITEM
  DEFECTIVE
  NOT_DELIVERED
  OVERAGE
}

enum MarketplaceDisputeStatus {
  OPEN
  VENDOR_RESPONSE
  ADMIN_REVIEW
  RESOLVED
}

enum MarketplaceTransactionStatus {
  PENDING
  AVAILABLE
  PAID_OUT
}

enum MarketplaceSenderType {
  BUYER
  VENDOR
  ADMIN
}

model Vendor {
  id              String         @id @default(uuid()) @db.Uuid
  workspaceId     String?        @map("workspace_id") @db.Uuid
  companyName     String         @map("company_name") @db.VarChar(255)
  legalName       String         @map("legal_name") @db.VarChar(255)
  type            VendorType
  status          VendorStatus   @default(PENDING)
  stripeAccountId String?        @map("stripe_account_id") @db.VarChar(255)
  commissionRate  Decimal        @default(5.0) @map("commission_rate") @db.Decimal(5, 2)
  planTier        VendorPlanTier @default(FREE) @map("plan_tier")
  verifiedAt      DateTime?      @map("verified_at")
  documents       Json           @default("[]")

  products         VendorProduct[]
  orders           MarketplacePurchaseOrder[]
  reviews          MarketplaceVendorReview[]
  transactions     VendorTransaction[]
  recurringOrders  MarketplaceRecurringOrder[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  workspace Workspace? @relation("VendorWorkspace", fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([workspaceId])
  @@map("marketplace_vendors")
}

model VendorProduct {
  id          String @id @default(uuid()) @db.Uuid
  vendorId    String @map("vendor_id") @db.Uuid
  name        String @db.VarChar(255)
  sku         String @db.VarChar(120)
  gtin        String? @db.VarChar(64)
  categoryId  String @map("category_id") @db.Uuid
  description String @db.Text
  richDescription String? @map("rich_description") @db.Text
  status      MarketplaceProductStatus @default(DRAFT)

  basePrice      Decimal              @map("base_price") @db.Decimal(14, 2)
  currency       MarketplaceCurrency  @default(USD)
  priceUnit      MarketplacePriceUnit @map("price_unit")
  caseSize       Int?                 @map("case_size")
  moq            Int                  @default(1)
  orderIncrement Int                  @default(1) @map("order_increment")

  stockQty        Int     @default(0) @map("stock_qty")
  minStockAlert   Int?    @map("min_stock_alert")
  leadTimeDays    Int     @default(3) @map("lead_time_days")
  allowBackorder  Boolean @default(false) @map("allow_backorder")

  weight               Decimal?                       @db.Decimal(12, 4)
  weightUnit           MarketplaceWeightUnit?         @map("weight_unit")
  dimensions           Json?
  storageRequirement   MarketplaceStorageRequirement? @map("storage_requirement")

  certifications String[] @default([])
  attributes     Json     @default("{}")
  tags           String[] @default([])

  media     Json     @default("[]")
  documents String[] @default([])

  seoTitle       String? @map("seo_title") @db.VarChar(255)
  seoDescription String? @map("seo_description") @db.Text
  slug           String  @unique @db.VarChar(255)

  variants      MarketplaceProductVariant[]
  volumePricing MarketplaceVolumePrice[]
  orderItems    MarketplacePOLineItem[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  vendor   Vendor                    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  category MarketplaceProductCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@unique([vendorId, sku])
  @@index([categoryId])
  @@index([status])
  @@index([vendorId, status])
  @@map("marketplace_vendor_products")
}

model MarketplaceProductCategory {
  id          String  @id @default(uuid()) @db.Uuid
  name        String  @db.VarChar(255)
  slug        String  @unique @db.VarChar(255)
  description String? @db.Text
  parentId    String? @map("parent_id") @db.Uuid
  level       Int     @default(1)
  icon        String? @db.VarChar(120)
  sortOrder   Int     @default(0) @map("sort_order")

  parent   MarketplaceProductCategory?  @relation("MarketplaceCategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children MarketplaceProductCategory[] @relation("MarketplaceCategoryHierarchy")
  products VendorProduct[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([parentId])
  @@map("marketplace_product_categories")
}

model MarketplaceProductVariant {
  id        String  @id @default(uuid()) @db.Uuid
  productId String  @map("product_id") @db.Uuid
  name      String  @db.VarChar(255)
  sku       String  @db.VarChar(120)
  price     Decimal? @db.Decimal(14, 2)
  stockQty  Int     @default(0) @map("stock_qty")
  attributes Json   @default("{}")

  orderItems MarketplacePOLineItem[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  product VendorProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, sku])
  @@map("marketplace_product_variants")
}

model MarketplaceVolumePrice {
  id          String  @id @default(uuid()) @db.Uuid
  productId   String  @map("product_id") @db.Uuid
  minQuantity Int     @map("min_quantity")
  price       Decimal @db.Decimal(14, 2)

  product VendorProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, minQuantity])
  @@map("marketplace_volume_prices")
}

model MarketplacePurchaseOrder {
  id          String @id @default(uuid()) @db.Uuid
  workspaceId String @map("workspace_id") @db.Uuid
  vendorId    String @map("vendor_id") @db.Uuid
  status      MarketplacePOStatus @default(DRAFT)

  subtotal    Decimal @db.Decimal(14, 2)
  deliveryFee Decimal @default(0) @map("delivery_fee") @db.Decimal(14, 2)
  total       Decimal @db.Decimal(14, 2)
  currency    MarketplaceCurrency @default(USD)

  paymentMethod   MarketplacePaymentMethod @map("payment_method")
  paymentIntentId String?                  @map("payment_intent_id") @db.VarChar(255)

  deliveryAddress       Json    @map("delivery_address")
  requestedDeliveryDate DateTime? @map("requested_delivery_date")
  confirmedDeliveryDate DateTime? @map("confirmed_delivery_date")
  trackingNumber        String?   @map("tracking_number") @db.VarChar(255)

  poNumber String? @map("po_number") @db.VarChar(64)
  notes    String? @db.Text

  approvedById String?   @map("approved_by_id") @db.Uuid
  approvedAt   DateTime? @map("approved_at")

  items             MarketplacePOLineItem[]
  review            MarketplaceVendorReview?
  dispute           MarketplaceDispute?
  vendorTransaction VendorTransaction?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  vendor    Vendor    @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  workspace Workspace @relation("MarketplacePurchaseOrderWorkspace", fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([vendorId])
  @@index([status])
  @@index([workspaceId, status])
  @@map("marketplace_purchase_orders")
}

model MarketplacePOLineItem {
  id              String @id @default(uuid()) @db.Uuid
  purchaseOrderId String @map("purchase_order_id") @db.Uuid
  productId       String @map("product_id") @db.Uuid
  variantId       String? @map("variant_id") @db.Uuid
  productName     String @map("product_name") @db.VarChar(255)
  sku             String @db.VarChar(120)
  quantity        Int
  unitPrice       Decimal @map("unit_price") @db.Decimal(14, 2)
  total           Decimal @db.Decimal(14, 2)
  receivedQuantity Int    @default(0) @map("received_quantity")
  returnedQuantity Int    @default(0) @map("returned_quantity")

  purchaseOrder MarketplacePurchaseOrder  @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       VendorProduct             @relation(fields: [productId], references: [id], onDelete: Restrict)
  variant       MarketplaceProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([purchaseOrderId])
  @@index([productId])
  @@map("marketplace_po_line_items")
}

model MarketplaceRecurringOrder {
  id               String @id @default(uuid()) @db.Uuid
  workspaceId      String @map("workspace_id") @db.Uuid
  vendorId         String @map("vendor_id") @db.Uuid
  name             String @db.VarChar(255)
  items            Json
  frequency        MarketplaceRecurringFrequency
  nextRunAt        DateTime @map("next_run_at")
  lastRunAt        DateTime? @map("last_run_at")
  isActive         Boolean @default(true) @map("is_active")
  approvalRequired Boolean @default(false) @map("approval_required")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  vendor    Vendor    @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  workspace Workspace @relation("MarketplaceRecurringOrderWorkspace", fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([vendorId])
  @@index([nextRunAt, isActive])
  @@map("marketplace_recurring_orders")
}

model MarketplaceCart {
  id          String @id @default(uuid()) @db.Uuid
  workspaceId String @unique @map("workspace_id") @db.Uuid
  items       Json   @default("[]")
  savedAt     DateTime @default(now()) @map("saved_at")
  expiresAt   DateTime? @map("expires_at")

  workspace Workspace @relation("MarketplaceCartWorkspace", fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("marketplace_carts")
}

model MarketplaceVendorReview {
  id              String @id @default(uuid()) @db.Uuid
  vendorId        String @map("vendor_id") @db.Uuid
  workspaceId     String @map("workspace_id") @db.Uuid
  purchaseOrderId String @unique @map("purchase_order_id") @db.Uuid
  qualityScore    Int    @map("quality_score")
  accuracyScore   Int    @map("accuracy_score")
  deliveryScore   Int    @map("delivery_score")
  packagingScore  Int    @map("packaging_score")
  overall         Int
  comment         String? @db.Text
  isPublic        Boolean @default(true) @map("is_public")

  createdAt DateTime @default(now()) @map("created_at")

  vendor        Vendor                   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  workspace     Workspace                @relation("MarketplaceVendorReviewWorkspace", fields: [workspaceId], references: [id], onDelete: Cascade)
  purchaseOrder MarketplacePurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, purchaseOrderId])
  @@index([vendorId])
  @@map("marketplace_vendor_reviews")
}

model MarketplaceDispute {
  id              String @id @default(uuid()) @db.Uuid
  purchaseOrderId String @unique @map("purchase_order_id") @db.Uuid
  openedById      String @map("opened_by_id") @db.Uuid
  reason          MarketplaceDisputeReason
  description     String @db.Text
  photos          String[] @default([])
  status          MarketplaceDisputeStatus @default(OPEN)
  resolution      String? @db.Text
  resolvedById    String? @map("resolved_by_id") @db.Uuid
  resolvedAt      DateTime? @map("resolved_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  purchaseOrder MarketplacePurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("marketplace_disputes")
}

model VendorTransaction {
  id               String @id @default(uuid()) @db.Uuid
  vendorId         String @map("vendor_id") @db.Uuid
  purchaseOrderId  String @unique @map("purchase_order_id") @db.Uuid
  grossAmount      Decimal @map("gross_amount") @db.Decimal(14, 2)
  commissionAmount Decimal @map("commission_amount") @db.Decimal(14, 2)
  netAmount        Decimal @map("net_amount") @db.Decimal(14, 2)
  status           MarketplaceTransactionStatus @default(PENDING)
  payoutId         String? @map("payout_id") @db.VarChar(255)
  availableAt      DateTime? @map("available_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  vendor        Vendor                   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  purchaseOrder MarketplacePurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([vendorId])
  @@index([status])
  @@map("marketplace_vendor_transactions")
}

model VendorMessage {
  id              String  @id @default(uuid()) @db.Uuid
  purchaseOrderId String? @map("purchase_order_id") @db.Uuid
  senderId        String  @map("sender_id") @db.Uuid
  senderType      MarketplaceSenderType @map("sender_type")
  message         String  @db.Text
  attachments     String[] @default([])
  readAt          DateTime? @map("read_at")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([purchaseOrderId])
  @@map("marketplace_vendor_messages")
}

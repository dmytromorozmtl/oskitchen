model WorkspaceMember {
  id          String              @id @default(uuid()) @db.Uuid
  workspaceId String              @map("workspace_id") @db.Uuid
  userId      String              @map("user_id") @db.Uuid
  role        WorkspaceMemberRole @default(STAFF)
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userProfile UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
  @@map("workspace_members")
}

/// Per-workspace SSO configuration (R2 pilot foundation — disabled by default).
model WorkspaceSsoSettings {
  id                     String        @id @default(uuid()) @db.Uuid
  workspaceId            String        @unique @map("workspace_id") @db.Uuid
  enabled                Boolean       @default(false)
  idpVendor              SsoIdpVendor? @map("idp_vendor")
  allowedEmailDomains    String[]      @default([]) @map("allowed_email_domains")
  /// Supabase Auth SSO provider reference (dashboard-configured; not raw SAML metadata).
  supabaseSsoProviderRef String?       @map("supabase_sso_provider_ref") @db.VarChar(255)
  breakGlassOwnerEnabled Boolean       @default(true) @map("break_glass_owner_enabled")
  pilotPhase             SsoPilotPhase @default(DISABLED) @map("pilot_phase")
  loginHintDomain        String?       @map("login_hint_domain") @db.VarChar(255)
  notes                  String?       @db.Text
  configuredByUserId     String?       @map("configured_by_user_id") @db.Uuid
  configuredAt           DateTime?     @map("configured_at")
  createdAt              DateTime      @default(now()) @map("created_at")
  updatedAt              DateTime      @updatedAt @map("updated_at")

  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  configuredBy UserProfile? @relation("WorkspaceSsoSettingsConfiguredBy", fields: [configuredByUserId], references: [id], onDelete: SetNull)

  @@map("workspace_sso_settings")
}

/// Links IdP subject (SAML NameID / OIDC sub) to KitchenOS user within a workspace.
model SsoIdentity {
  id          String       @id @default(uuid()) @db.Uuid
  workspaceId String       @map("workspace_id") @db.Uuid
  userId      String       @map("user_id") @db.Uuid
  idpVendor   SsoIdpVendor @map("idp_vendor")
  idpSubject  String       @map("idp_subject") @db.VarChar(512)
  emailAtLink String?      @map("email_at_link") @db.VarChar(255)
  lastLoginAt DateTime?    @map("last_login_at")
  linkedAt    DateTime     @default(now()) @map("linked_at")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userProfile UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, idpVendor, idpSubject])
  @@unique([workspaceId, userId, idpVendor])
  @@index([userId])
  @@map("sso_identities")
}

/// Workspace SCIM 2.0 provisioning settings (pilot foundation — disabled by default).
enum ScimPilotPhase {
  DISABLED
  PILOT_CONFIGURED
  PILOT_ACTIVE
}

model WorkspaceScimSettings {
  id                 String         @id @default(uuid()) @db.Uuid
  workspaceId        String         @unique @map("workspace_id") @db.Uuid
  enabled            Boolean        @default(false)
  tokenHash          String         @map("token_hash") @db.VarChar(128)
  pilotPhase         ScimPilotPhase @default(DISABLED) @map("pilot_phase")
  lastRotatedAt      DateTime?      @map("last_rotated_at")
  configuredByUserId String?        @map("configured_by_user_id") @db.Uuid
  configuredAt       DateTime?      @map("configured_at")
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")

  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  configuredBy UserProfile? @relation("WorkspaceScimSettingsConfiguredBy", fields: [configuredByUserId], references: [id], onDelete: SetNull)

  @@map("workspace_scim_settings")
}

/// SCIM-provisioned user linkage within a workspace (RFC 7644 User resource id).
model ScimProvisionedUser {
  id          String              @id @default(uuid()) @db.Uuid
  workspaceId String              @map("workspace_id") @db.Uuid
  userId      String              @map("user_id") @db.Uuid
  externalId  String?             @map("external_id") @db.VarChar(512)
  idpSubject  String?             @map("idp_subject") @db.VarChar(512)
  userName    String              @map("user_name") @db.VarChar(255)
  active      Boolean             @default(true)
  role        WorkspaceMemberRole @default(STAFF)
  lastSyncAt  DateTime            @default(now()) @map("last_sync_at")
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userProfile UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userName])
  @@unique([workspaceId, externalId])
  @@index([userId])
  @@map("scim_provisioned_users")
}


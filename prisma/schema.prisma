  /// When true, owner marked menu ready for external / marketing surfaces (activeMenuId still drives checkout).
  published        Boolean  @default(false)
  startDate        DateTime @map("start_date") @db.Date
  endDate          DateTime @map("end_date") @db.Date
  preorderDeadline DateTime @map("preorder_deadline")
  /// Prepared-date hints for meal-prep / catering production (JSON array of ISO dates or objects).
  preparedDatesJson Json?   @map("prepared_dates_json")

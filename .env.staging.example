# =============================================================================
# KitchenOS — STAGING / CLOSED BETA template
# Copy to Vercel → staging environment or `.env.staging.local` (never commit secrets).
# Validate: npm run verify:staging-env
# =============================================================================

NODE_ENV=production
NEXT_PUBLIC_APP_ENV=staging
NEXT_PUBLIC_APP_URL=https://staging.yourdomain.com

# --- Database (Supabase poolers) ---
DATABASE_URL="postgresql://postgres.PROJECT:PASSWORD@aws-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=10"
DIRECT_URL="postgresql://postgres.PROJECT:PASSWORD@aws-REGION.pooler.supabase.com:5432/postgres"

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Security (required) ---
ENCRYPTION_KEY=
CRON_SECRET=

# --- Rate limits (REQUIRED on staging pilot — not memory) ---
RATE_LIMIT_ADAPTER=upstash
UPSTASH_REDIS_REST_URL=https://YOUR-ENDPOINT.upstash.io
UPSTASH_REDIS_REST_TOKEN=

# --- Platform impersonation (use ONE) ---
PLATFORM_IMPERSONATION_TOTP_SECRET=
# PLATFORM_IMPERSONATION_STEP_UP_TOKEN=

# --- Email ---
RESEND_API_KEY=
RESEND_FROM_EMAIL="KitchenOS <notifications@yourdomain.com>"

# --- Stripe (test mode on staging) ---
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_

# --- Smoke / QA (local shell only — not Vercel) ---
# SMOKE_BASE_URL=https://staging.yourdomain.com
# SMOKE_PUBLIC_API_KEY=kos_...
# SMOKE_SESSION_COOKIE=
# SMOKE_DELIVERY_CONNECTION_ID=
# SMOKE_DELIVERY_CONNECTION_ID_OTHER=
# E2E_LOGIN_EMAIL=
# E2E_LOGIN_PASSWORD=
# E2E_STAFF_EMAIL=          # workspace staff member (step 5 E2E)
# E2E_STAFF_PASSWORD=
# BETA_COHORT_EMAILS=owner1@,owner2@,owner3@
# BETA_OWNER_EMAIL=owner1@          # step 5 staff parity check
# BETA_SLACK_WEBHOOK_URL=           # optional Week 1 Slack digest for beta:daily-ops

# --- Pilot nav (REQUIRED for paid pilot) ---
NEXT_PUBLIC_NAV_RELEASE_PROFILE=pilot

# Keep experimental crons OFF for smoke:
# ENABLE_EXPERIMENTAL_CRONS=
